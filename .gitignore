# ===========================================================================
# .gitignore — AI Powered Career Learning Platform
# ===========================================================================

# ---------------------------------------------------------------------------
# 🔐 SENSITIVE / SECRET FILES — Never commit these!
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example          # Allow the example/template file
*.pem
*.key
secrets/

# ---------------------------------------------------------------------------
# 🐍 Python Virtual Environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.venv*/
venv*/

# ---------------------------------------------------------------------------
# 🐍 Python General
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# ---------------------------------------------------------------------------
# 📦 Node.js / Frontend
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# Build outputs
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/
*.local

# ---------------------------------------------------------------------------
# 🐳 Docker
# ---------------------------------------------------------------------------
*.log
docker-compose.override.yml

# ---------------------------------------------------------------------------
# 🗄️ Database
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
database/data/
pgdata/

# ---------------------------------------------------------------------------
# 🖥️ IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# 📝 Logs & Temp Files
# ---------------------------------------------------------------------------
logs/
*.log
*.tmp
*.temp
*.bak
*.orig

# ---------------------------------------------------------------------------
# 🔧 Alembic / Migrations (keep migration files, ignore generated cache)
# ---------------------------------------------------------------------------
# (migration scripts ARE committed — do not ignore alembic/)

# ---------------------------------------------------------------------------
# 📊 Testing & Coverage
# ---------------------------------------------------------------------------
htmlcov/
.coverage
coverage.xml
test-results/

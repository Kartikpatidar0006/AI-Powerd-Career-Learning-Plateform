# ===========================================================================
# backend/.env.example
# ---------------------
# Copy this file to `.env` and fill in your actual values.
# Never commit the real `.env` to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Project
# ---------------------------------------------------------------------------
PROJECT_NAME="AI Powered Career Learning Platform"
PROJECT_VERSION="0.1.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# ---------------------------------------------------------------------------
# Security  ⚠️  Generate a real key: openssl rand -hex 32
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=career_platform

# Optional: provide a full DSN to override the assembled one above.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/career_platform

# ---------------------------------------------------------------------------
# CORS  (comma-separated list of allowed origins)
# ---------------------------------------------------------------------------
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# SQLAlchemy connection pool
# ---------------------------------------------------------------------------
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false
